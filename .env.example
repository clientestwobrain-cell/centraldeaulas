APP_ENV=local
APP_DEBUG=true
APP_KEY=centraldeaulas-local-change-me

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_SOCKET=
DB_DATABASE=centraldeaulas
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PERSISTENT=false
DB_TIMEOUT=5
DB_AUTO_MIGRATE=true

API_CORS_ALLOWED_ORIGINS=*
API_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
API_CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
API_ADMIN_TOKEN=centraldeaulas-local-api-token

ADMIN_BOOTSTRAP_NAME=Administrador
ADMIN_BOOTSTRAP_EMAIL=admin@centraldeaulas.local
ADMIN_BOOTSTRAP_PASSWORD=admin123456
ADMIN_SESSION_NAME=centraldeaulas_admin
